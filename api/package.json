{
  "name": "honeymanlabs-api",
  "version": "1.0.0",
  "description": "our backend api service for te honeyman ecosystem",
  "keywords": [
    "api",
    "honeyman",
    "honeymanlabs",
    "ecosystem"
  ],
  "license": "ISC",
  "author": "Ayeah Godlove Akoni",
  "engines": {
    "node": "20.18.2"
  },
  "type": "commonjs",
  "main": "build/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node build/server.js",
    "migration:generate": "sequelize-cli migration:generate --name",
    "migration:up": "sequelize-cli db:migrate",
    "migration:down": "sequelize-cli db:migrate:undo",
    "migration:status": "sequelize-cli db:migrate:status",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "mysql2": "^3.20.0",
    "nodemailer": "^8.0.3",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6",
    "zod-express-middleware": "^1.4.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/sequelize": "^4.28.20",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "sequelize-cli": "^6.6.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
