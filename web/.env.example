NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Cloudinary — unsigned upload from the browser (dashboard: Settings → Upload → Upload presets)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset
# Optional — only if you use the Node SDK or signed uploads server-side (never NEXT_PUBLIC_)
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
